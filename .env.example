# ==============================================================================
# CARS SR99 Kft. - Production Environment Variables
# Fill in these values in your Vercel Dashboard (Project Settings > Environment Variables)
# ==============================================================================

# Google Analytics 4 (GA4) Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public site URL used for canonical URLs, robots.txt, and sitemap.xml
NEXT_PUBLIC_SITE_URL=https://cars-sr99.com

# Google Search Console Verification Meta Tag Code
NEXT_PUBLIC_GSC_VERIFICATION=

# Meta (Facebook) Pixel ID (e.g. 123456789012345)
NEXT_PUBLIC_META_PIXEL_ID=

# HubSpot Portal / Hub ID (e.g. 14352678)
HUBSPOT_PORTAL_ID=

# HubSpot Form GUIDs for API Submissions
HUBSPOT_CONTACT_FORM_GUID=
HUBSPOT_TRADEIN_FORM_GUID=

# Production Lead Capture Webhook Endpoint (e.g. n8n, Make, Zapier, or custom API)
NEXT_PUBLIC_LEAD_WEBHOOK_URL=
